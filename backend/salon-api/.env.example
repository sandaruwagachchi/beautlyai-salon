# AWS Development Environment Configuration
# Copy to .env and fill in your values

# ============================================
# AWS Credentials (from beautlyai-dev-user)
# ============================================
# Replace with your own AWS credentials or use an AWS profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_PROFILE=beautlyai-dev

# ============================================
# AWS S3 Buckets (Development)
# ============================================
AWS_S3_UPLOADS_BUCKET=beautlyai-dev-uploads
AWS_S3_EXPORTS_BUCKET=beautlyai-dev-exports
AWS_S3_STATIC_BUCKET=beautlyai-dev-static

# ============================================
# AWS SSM Parameter Store Paths
# ============================================
# Secrets are stored here instead of .env
# Access via AWS SDK: ssm:GetParameter
SSM_DB_PASSWORD=/beautlyai/dev/db/password
SSM_JWT_SECRET=/beautlyai/dev/jwt/secret

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection (local or RDS)
DATABASE_URL=jdbc:postgresql://localhost:5432/beautylai_dev
DATABASE_USER=beautylai_admin
SPRING_DATASOURCE_PASSWORD=${SSM_DB_PASSWORD}

# ============================================
# Spring Application
# ============================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BEAUTLYAI=DEBUG

# ============================================
# Redis Cache (Optional)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=60000

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_BASE64=${SSM_JWT_SECRET}
JWT_EXPIRATION=3600000

# ============================================
# Application Settings
# ============================================
APP_NAME=BeautlyAI Salon API
APP_VERSION=0.0.1-SNAPSHOT
APP_ENVIRONMENT=development

